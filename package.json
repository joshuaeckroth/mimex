{
  "name": "mimex",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.30.1",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "desktop:prepare": "pnpm --filter @mimex/shared-types build && pnpm --filter @mimex/core build && pnpm --filter @mimex/api build && pnpm --filter @mimex/web build",
    "desktop:dev": "pnpm run desktop:prepare && pnpm --filter @mimex/desktop dev",
    "desktop:start": "pnpm --filter @mimex/desktop start",
    "desktop:nsis": "pnpm run desktop:prepare && pnpm --filter @mimex/desktop dist:win",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "@types/node": "^20.17.24",
    "tsx": "^4.19.2",
    "turbo": "^2.5.6",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
