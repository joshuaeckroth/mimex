{
  "name": "@mimex/tui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mimex": "dist/index.js"
  },
  "scripts": {
    "build": "pnpm --filter @mimex/core build && tsc -p tsconfig.json",
    "dev": "pnpm --filter @mimex/core build && tsx src/index.tsx",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "echo 'no tests for tui yet'",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@mimex/core": "workspace:*",
    "@mimex/shared-types": "workspace:*",
    "ink": "^5.2.1",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.11"
  }
}
