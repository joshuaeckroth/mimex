{
  "name": "@mimex/tui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mimex": "dist/index.js"
  },
  "scripts": {
    "build": "pnpm --filter @mimex/core build && tsc -p tsconfig.json",
    "dev": "pnpm --filter @mimex/core build && tsx src/index.tsx",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@mimex/core": "workspace:*",
    "@mimex/shared-types": "workspace:*",
    "@types/blessed": "^0.1.27",
    "neo-blessed": "^0.2.0"
  }
}
